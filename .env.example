# My Lingo —— 真实 LLM E2E 测试所需凭证（复制为 .env 后填入真实值）
#   cp .env.example .env  &&  编辑 .env  &&  npm run test:e2e
# 任意 OpenAI 兼容服务商均可：OpenAI、DeepSeek、Groq、本地 Ollama 等。
MY_LINGO_API_KEY=sk-...
MY_LINGO_API_BASE_URL=https://api.openai.com/v1   # 或你的服务商地址
MY_LINGO_MODEL_FAST=gpt-4o-mini                   # 优化/分析用的快模型
MY_LINGO_MODEL_DEEP=gpt-4o                         # 课程生成用的深模型（可选，默认同 FAST）
